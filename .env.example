PHISHNET_API_KEY=your_key_here
PHISHPICKER_ADMIN_TOKEN=generate_with__openssl_rand_hex_32

# Host-side path where the SQLite DB + model artifacts live. The api container
# mounts this read-only-ish for runtime; the Mac mini ships new DB snapshots
# into this same path via scp.
PHISHPICKER_DATA_HOST=/home/Murphy52/docker/apps/phishpicker/data

# Host-side port for the web UI. Bound to 127.0.0.1 only; front with a
# Cloudflare tunnel for external access.
PHISHPICKER_WEB_PORT=3400
